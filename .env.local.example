# ── Admin email (propietario del panel de administración) ────
ADMIN_EMAIL=conectar.rrhh.ar@gmail.com

# ── Google OAuth (opcional, para "Continuar con Google") ────
# Configurar en: Supabase Dashboard > Auth > Providers > Google
# Y en: Google Cloud Console > APIs & Services > Credentials
# (No se necesita acá — se configura directo en Supabase)

# ── Stripe (pagos y suscripciones) ─────────────────────────
# Dashboard: stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard: stripe.com → Products → Price IDs
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ── Sentry (monitoreo de errores) ──────────────────────────
# Dashboard: sentry.io → Settings → Projects → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Google Analytics 4 ──────────────────────────────────────
# Dashboard: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Crisp Chat ───────────────────────────────────────────────
# Dashboard: app.crisp.chat → Settings → Website → Website ID
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Resend (emails transaccionales) ────────────────────────
# Crear cuenta en resend.com, obtener API key y verificar dominio
# Sin estas vars los emails se silencian (la app funciona igual)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ConectAr Talento <no-reply@tudominio.com>
