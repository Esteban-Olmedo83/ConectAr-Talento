# ── Supabase ────────────────────────────────────────────────
# Encontrá estos valores en: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xwsgoegiwducmytntdba.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ── Supabase Service Role (solo para rutas de admin — nunca exponer al cliente) ──
# Encontrá este valor en: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin email (propietario del panel de administración) ────
ADMIN_EMAIL=conectar.rrhh.ar@gmail.com

# ── URL pública de la app (OBLIGATORIO) ─────────────────────
# En desarrollo: http://localhost:3000
# En producción: tu dominio real (ej: https://www.conectartalento.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Groq AI (análisis de CV, generación de JD e informes) ───
# Obtené tu key gratis en: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Sentry (monitoreo de errores en producción) ──────────────
# Obtené el DSN en: sentry.io > Settings > Projects > Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://bf181865feabbd44c7e6874220dd3ab4@o4511493471928320.ingest.us.sentry.io/4511622264389632
SENTRY_DSN=https://bf181865feabbd44c7e6874220dd3ab4@o4511493471928320.ingest.us.sentry.io/4511622264389632
SENTRY_AUTH_TOKEN=

# ── Google OAuth (login con Google) ─────────────────────────
# Configurar en: Supabase Dashboard > Auth > Providers > Google
# (No se necesita acá — se configura directo en Supabase)

# ── Google Workspace Integration (Gmail, Drive, Calendar) ───
# Configurar en: Google Cloud Console > APIs & Services > Credentials
# Tipo: OAuth 2.0 Client ID (Web application)
# URI de redirección autorizada: ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
# Ej. producción: https://www.conectartalento.com/api/oauth/google/callback
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Stripe (pagos y suscripciones) ─────────────────────────
# Dashboard: stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard: stripe.com → Products → Price IDs
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ── Google Analytics 4 ──────────────────────────────────────
# Dashboard: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Crisp Chat ───────────────────────────────────────────────
# Dashboard: app.crisp.chat → Settings → Website → Website ID
